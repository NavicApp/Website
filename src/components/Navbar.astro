---
import Matrix from "@icons/matrix.svg";
import Discord from "@icons/discord.svg";
import Codeberg from "@icons/codeberg.svg";
import GitHub from "@icons/github.svg";
import Button from "@components/Button.astro";
const links = [
	{ href: "/", title: "Home" },
	{ href: "/downloads", title: "Downloads" },
	{ href: "/faq", title: "FAQ" },
];
---

<nav>
	<div class="content-container">
		{
			links.map((link) => (
				<Button
					href={link.href}
					isSquare
					variant={
						link.href === Astro.url.pathname ? "tonal" : "text"
					}
				>
					{link.title}
				</Button>
			))
		}
		<div class="spacer"></div>
		<Button
			variant="text"
			isSquare
			className="social"
			href="https://matrix.to/#/#navic:maize.moe"
		>
			<Matrix />
		</Button>
		<Button
			variant="text"
			isSquare
			className="social"
			href="https://discord.gg/TBcnNX66PH"
		>
			<Discord />
		</Button>
		<Button
			variant="text"
			isSquare
			className="social"
			href="https://codeberg.org/paige/Navic"
		>
			<Codeberg />
		</Button>
		<Button
			variant="text"
			isSquare
			className="social"
			href="https://github.com/paigely/Navic"
		>
			<GitHub />
		</Button>
	</div>
</nav>

<style>
	nav {
		width: 100%;
		background: var(--m3c-surface-container-high);
		box-shadow: var(--m3-elevation-1);
		color: #fff;
		padding: 15px 0;
		position: sticky;
		top: 0;
	}
	.content-container {
		display: flex;
		align-items: center;
	}
	.spacer {
		flex: 1;
	}
	nav :global(a) {
		margin-top: 0 !important;
	}
	:global(.social) {
		padding: 0 !important;
		width: 40px !important;
		height: 40px !important;
	}
</style>
