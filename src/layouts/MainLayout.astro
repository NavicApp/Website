---
import "@/app.css";
import Head from "@components/Head.astro";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
interface Props {
	title?: string;
}
const { title = "" } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<Head title={title} />
	</head>
	<body>
		<Navbar />

		<main class="content-container">
			<slot />
		</main>

		<Footer />
	</body>
</html>
