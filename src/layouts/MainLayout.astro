---
import "@/app.css";
import { pageTransition } from "@/constants";
import Footer from "@components/Footer.astro";
import Head from "@components/Head.astro";
import Navbar from "@components/Navbar.astro";
interface Props {
	title?: string;
	description?: string;
	type?: string;
	mainEntity?: any[];
}
const { title, description, type, mainEntity } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<Head
			title={title}
			description={description}
			type={type}
			mainEntity={mainEntity}
		/>
	</head>
	<body>
		<Navbar />

		<main class="content-container" transition:animate={pageTransition}>
			<slot />
		</main>

		<Footer />
		
		<script src="../scripts/ripple.ts" />
	</body>
</html>
