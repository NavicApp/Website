---
import library from "@assets/library.avif";
import Button from "@components/Button.astro";
import Card from "@components/Card.astro";
import Features from "@components/Features.astro";
import Code from "@icons/code.svg";
import Download from "@icons/download.svg";
import Layout from "@layouts/MainLayout.astro";
import { Image } from "astro:assets";
---

<Layout>
	<section>
		<Card className="hero" rounding="24px">
			<div class="hero-left">
				<h1>
					Stream music from <mark>Navidrome</mark> with <mark
						>Navic</mark
					>
				</h1>
				<p>
					Navic is a free and open source client for <a
						href="https://navidrome.org"
						target="_blank">Navidrome</a
					>, supporting Android and iOS.
				</p>
				<Button size="large" href="/downloads">
					<Download />
					Downloads
				</Button>
				<Button
					size="large"
					variant="tonal"
					href="https://github.com/paigely/Navic"
				>
					<Code />
					Source Code
				</Button>
			</div>
			<div class="hero-right">
				<Image
					src={library}
					alt="A screenshot of Navic's library tab"
				/>
			</div>
		</Card>
		<Features />
	</section>
</Layout>

<style>
	section {
		margin-top: 24px;
		margin-bottom: 24px;
	}
	h1 {
		font-weight: 400;
		font-size: 40px;
	}
	h2 {
		text-align: center;
		margin-top: 64px;
	}
	mark {
		color: var(--m3c-primary);
		background: none;
		font-weight: 600;
	}
	.hero {
		display: flex;
		align-items: center;
		gap: 120px;
		overflow: hidden;
	}
	.hero-left {
		flex: 1.2;
		padding-left: 10px;
	}
	.hero-right {
		flex: 1;
	}
	.hero-right > img {
		width: 100%;
		height: 600px;
		object-position: top;
		object-fit: cover;
		border-top-left-radius: 12px;
		border-top-right-radius: 12px;
		margin-bottom: -22px;
		box-shadow: var(--m3-elevation-1);
	}
	@media (max-width: 944px) {
		.hero-right {
			display: none;
		}
		.hero-left {
			padding-bottom: 10px;
		}
	}
	#table-desc {
		text-align: center;
	}
</style>
